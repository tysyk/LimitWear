# Application
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000
SWAGGER_ENABLED=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX=300
RATE_LIMIT_WINDOW_MS=60000

# Database
DATABASE_URL=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/limitwear?retryWrites=true&w=majority

# Authentication
JWT_SECRET=replace-with-a-long-random-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
COOKIE_SAME_SITE=lax
COOKIE_SECURE=false

# Monobank
MONO_TOKEN=replace-with-monobank-token
MONO_WEBHOOK_URL=https://example.com/webhooks/monobank
MONO_WEBHOOK_SECRET=replace-with-webhook-secret
MONO_API_BASE_URL=https://api.monobank.ua/api/merchant

# Nova Poshta
NOVA_POSHTA_API_KEY=replace-with-nova-poshta-api-key
NOVA_POSHTA_API_URL=https://api.novaposhta.ua/v2.0/json/

# S3-compatible storage (AWS S3, Cloudflare R2, or similar)
S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=limitwear-dev
S3_ACCESS_KEY_ID=replace-with-s3-access-key-id
S3_SECRET_ACCESS_KEY=replace-with-s3-secret-access-key
S3_PUBLIC_BASE_URL=https://cdn.example.com
S3_SIGNED_URL_EXPIRES_IN_SECONDS=900
